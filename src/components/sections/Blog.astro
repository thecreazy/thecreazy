---
import type { BlogPost } from '../../lib/types'

interface Props {
  posts: BlogPost[]
}

const { posts } = Astro.props

const byYear = posts.reduce<Record<number, BlogPost[]>>((acc, p) => {
  ;(acc[p.year] ??= []).push(p)
  return acc
}, {})

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a)
---

<section id="blog" class="section">
  <header class="section-header reveal">
    <span class="section-label font-pixel">03.</span>
    <h2 class="section-title font-terminal">what_i_write</h2>
  </header>

  <div class="blog-list">
    {
      years.map((year) => (
        <div class="year-group reveal">
          <div class="year-marker">
            <span class="year-label font-terminal">{year}</span>
            <div class="year-line" />
          </div>

          <ul class="posts-list">
            {byYear[year].map((post, i) => (
              <li class="post-item" style={`transition-delay: ${i * 40}ms`}>
                <a
                  href={post.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="post-link"
                  aria-label={post.title}
                >
                  <span class="post-tag font-terminal" aria-hidden="true">
                    {post.tag || '//'}
                  </span>
                  <span class="post-title font-mono">{post.title}</span>
                  <span class="post-arrow font-terminal" aria-hidden="true">
                    →
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .section {
    padding: 120px 0;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 60px;
  }

  .section-label {
    font-size: 12px;
    color: var(--color-accent);
  }

  .section-title {
    font-size: clamp(36px, 5vw, 56px);
    color: var(--color-text);
    line-height: 1;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .year-group {
  }

  .year-marker {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .year-label {
    font-size: 42px;
    color: var(--color-accent);
    line-height: 1;
    min-width: 80px;
  }

  .year-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .posts-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: padding-left 0.2s;
  }

  .post-link:hover {
    padding-left: 16px;
    opacity: 1;
  }

  .post-link:hover .post-arrow {
    color: var(--color-accent);
    transform: translate(4px, 0);
  }

  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-tag {
    font-size: 24px;
    min-width: 36px;
    color: var(--color-accent2);
  }

  .post-title {
    flex: 1;
    font-size: 14px;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .post-arrow {
    font-size: 20px;
    color: var(--color-dim);
    transition:
      color 0.2s,
      transform 0.2s;
  }
</style>
