---
import type { Project } from '../../lib/types'

interface Props {
  projects: Project[]
}

const { projects } = Astro.props
---

<section id="projects" class="section">
  <header class="section-header reveal">
    <span class="section-label font-pixel">02.</span>
    <h2 class="section-title font-terminal">what_i_code</h2>
  </header>

  <div class="projects-grid">
    {projects.map((p, i) => (
      <a
        href={p.url}
        target="_blank"
        rel="noopener noreferrer"
        class="project-card reveal"
        style={`transition-delay: ${i * 60}ms`}
        aria-label={`${p.name}: ${p.description}`}
      >
        <div class="card-index font-terminal">{String(i + 1).padStart(2, '0')}</div>
        <div class="card-content">
          <h3 class="card-name font-pixel glitch" data-text={p.name}>{p.name}</h3>
          <p class="card-desc font-mono">{p.description}</p>
        </div>
        <div class="card-arrow font-terminal" aria-hidden="true">→</div>
      </a>
    ))}
  </div>
</section>

<style>
  .section {
    padding: 120px 0;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 60px;
  }

  .section-label {
    font-size: 12px;
    color: var(--color-accent);
  }

  .section-title {
    font-size: clamp(36px, 5vw, 56px);
    color: var(--color-text);
    line-height: 1;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2px;
  }

  .project-card {
    display: grid;
    grid-template-columns: 40px 1fr 24px;
    gap: 16px;
    align-items: start;
    padding: 24px;
    border: 1px solid var(--color-border);
    margin: -1px 0 0 -1px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: inset 0 0 20px rgba(0,0,0,0.1), 0 0 20px var(--color-glow);
    z-index: 1;
    opacity: 1;
  }

  .card-index {
    font-size: 28px;
    color: var(--color-accent);
    line-height: 1.2;
  }

  .card-name {
    font-size: 12px;
    color: var(--color-accent);
    margin-bottom: 10px;
    line-height: 1.6;
  }

  .card-desc {
    font-size: 13px;
    color: var(--color-dim);
    line-height: 1.6;
  }

  .card-arrow {
    font-size: 24px;
    color: var(--color-dim);
    transition: color 0.2s, transform 0.2s;
    padding-top: 4px;
  }

  .project-card:hover .card-arrow {
    color: var(--color-accent);
    transform: translate(4px, -4px);
  }
</style>
